{
  "name": "berlin-thriller-auswahl",
  "version": "1.0.0",
  "description": "Auswahlformular für das Webspecial Topographie des Verbrechens - Berlin-Thriller.",
  "type": "module",
  "scripts": {
    "start": "wrangler dev",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create berlin_thriller_auswahl",
    "db:migrate:local": "wrangler d1 migrations apply berlin_thriller_auswahl --local",
    "db:migrate:remote": "wrangler d1 migrations apply berlin_thriller_auswahl --remote",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "wrangler": "^4.20.0"
  }
}
